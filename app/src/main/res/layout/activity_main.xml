<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center"
    android:padding="28dp" android:background="#0A0A0A">
    <TextView android:text="🎱" android:textSize="60sp" android:gravity="center"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>
    <TextView android:text="TacLines" android:textSize="28sp" android:textStyle="bold"
        android:textColor="#00FF88" android:gravity="center"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:text="Linhas de mira para sinuca"
        android:textSize="12sp" android:textColor="#555555" android:gravity="center"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"/>
    <TextView android:id="@+id/tvStatus"
        android:text="Pronto" android:textSize="14sp"
        android:textColor="#00FF88" android:gravity="center"
        android:padding="14dp" android:background="#181818"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"/>
    <Button android:id="@+id/btnStart"
        android:text="INICIAR LINHAS"
        android:textSize="14sp" android:textColor="#000000"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:layout_marginBottom="10dp" android:backgroundTint="#00FF88"/>
    <Button android:id="@+id/btnStop" android:text="PARAR"
        android:textSize="14sp" android:textColor="#FFFFFF"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:backgroundTint="#333333"/>
    <TextView
        android:text="\nComo usar:\n1. Toque INICIAR LINHAS\n2. Conceda as permissoes\n3. Abra seu jogo\n4. Toque ESCANEAR no painel\n5. Linha VERDE = vai entrar\n   Linha VERMELHA = bloqueada"
        android:textSize="12sp" android:textColor="#444444"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="20dp" android:lineSpacingExtra="3dp"/>
</LinearLayout>
